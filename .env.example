# ---------------------------------------------------------------------------
# Supabase Postgres
#
# Find these in your Supabase project:
#   Project Settings -> Database -> Connection string -> "URI" tab
#
# You need BOTH:
#   DATABASE_URL  -> "Transaction pooler"  (port 6543) used by the app
#   DIRECT_URL    -> "Direct connection"   (port 5432) used by migrations
#
# Replace [YOUR-PASSWORD] with your database password. If it contains any of
# @ : / ? # & % then URL-encode it (e.g. @ becomes %40) or the URL won't parse.
# ---------------------------------------------------------------------------

DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# ---------------------------------------------------------------------------
# Auth
#
# Each social media manager / agency creates their own account, and every
# account gets a fully isolated workspace. Client approval links (/share/...)
# stay public by design — clients approve content without an account.
#
# AUTH_SECRET signs session cookies. Use a long random value; changing it
# signs everyone out. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
#
# INVITE_CODE gates signup — nobody can create an account without it. Share it
# only with people you want to have access.
# ---------------------------------------------------------------------------

AUTH_SECRET="a-long-random-string"
INVITE_CODE="choose-an-invite-code"

# ---------------------------------------------------------------------------
# Stripe billing (optional — the app runs without it; everyone stays on Free)
#
# 1. Create a Stripe account, then in the Dashboard create three recurring
#    Products/Prices: Freelancer $19/mo, Agency $59/mo, Studio $129/mo.
# 2. Paste the secret key and the three price ids (price_...) below.
# 3. Set up a webhook endpoint pointing at  <your-domain>/api/billing/webhook
#    for these events: checkout.session.completed, customer.subscription.*
#    and paste its signing secret as STRIPE_WEBHOOK_SECRET.
#
# NEXT_PUBLIC_SITE_URL should be your deployed URL so Stripe redirects land
# back on the right place (falls back to VERCEL_URL, then localhost).
# ---------------------------------------------------------------------------

# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# STRIPE_PRICE_FREELANCER="price_..."
# STRIPE_PRICE_AGENCY="price_..."
# STRIPE_PRICE_STUDIO="price_..."
# NEXT_PUBLIC_SITE_URL="https://your-domain.com"
