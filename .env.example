# ---------------------------------------------------------------------------
# Supabase Postgres
#
# Find these in your Supabase project:
#   Project Settings -> Database -> Connection string -> "URI" tab
#
# You need BOTH:
#   DATABASE_URL  -> "Transaction pooler"  (port 6543) used by the app
#   DIRECT_URL    -> "Direct connection"   (port 5432) used by migrations
#
# Replace [YOUR-PASSWORD] with your database password. If it contains any of
# @ : / ? # & % then URL-encode it (e.g. @ becomes %40) or the URL won't parse.
# ---------------------------------------------------------------------------

DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# ---------------------------------------------------------------------------
# Password gate
#
# Protects the manager-facing app. Client approval links (/share/...) stay
# public by design — clients approve content without an account.
#
# This value also signs the session cookie, so changing it signs everyone out.
# ---------------------------------------------------------------------------

APP_PASSWORD="choose-a-strong-password"
